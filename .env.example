# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# TLS / Origin
APP_ORIGIN=https://example.com
TRUST_PROXY=1

# Security
CSP_REPORT_URI=/csp-report
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# DO NOT COMMIT A REAL .env FILE. Copy this to .env locally.
