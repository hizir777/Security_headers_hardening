# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Explicitly declare text files
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.sh     text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary

# Linguist overrides (helps GitHub language stats)
docs/*   linguist-documentation
tests/*  linguist-detectable
