{
  "name": "security-headers-hardening",
  "version": "1.0.0",
  "description": "Production-ready Express template implementing the six core OWASP-aligned security headers with strict nonce-based CSP, Trusted Types, HSTS preload, and full audit tooling.",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development node --watch src/server.js",
    "test": "jest --coverage",
    "test:headers": "bash scripts/audit-headers.sh",
    "lint": "eslint src/ tests/",
    "audit": "npm audit --audit-level=high",
    "docker:build": "docker build -t security-headers-hardening:latest .",
    "docker:run": "docker compose up --build"
  },
  "keywords": [
    "security",
    "csp",
    "hsts",
    "helmet",
    "owasp",
    "devsecops",
    "express",
    "trusted-types",
    "permissions-policy"
  ],
  "author": "Istinye University - Secure Web Development",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
